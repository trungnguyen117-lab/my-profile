---
interface Props {
  id: string;
  title: string;
  authors?: string;
  venue?: string;
  date?: string;
  status?: string;
  tags?: { id: string; name: string }[];
  pdfLink?: string;
}

const { id, title, authors, venue, date, status, tags, pdfLink } = Astro.props;
---

<a href={`/research/${id}`} class="group block card">
  <div class="flex flex-col gap-3">
    <div class="flex items-start justify-between gap-4">
      <h3 class="text-[15px] font-semibold leading-snug group-hover:text-accent transition-colors duration-300 tracking-tight">
        {title}
      </h3>
      {pdfLink && (
        <span class="shrink-0 text-xs text-text-3 font-mono group-hover:text-accent transition-colors duration-300 flex items-center gap-1 mt-0.5">
          pdf
          <svg class="w-3 h-3 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10"/>
          </svg>
        </span>
      )}
    </div>
    {authors && <p class="text-xs text-text-3 leading-relaxed">{authors}</p>}
    <div class="flex flex-wrap items-center gap-2">
      {venue && <span class="tag-pill">{venue}</span>}
      {date && <span class="text-xs text-text-3 font-mono">{new Date(date).getFullYear()}</span>}
      {status && <span class="text-xs text-text-2 font-medium">{status}</span>}
      {tags && tags.map(t => <span class="text-xs text-text-3 font-mono">#{t.name}</span>)}
    </div>
  </div>
</a>
