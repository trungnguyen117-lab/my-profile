---
interface Props {
  title?: string;
}
const { title = 'terminal' } = Astro.props;
---

<div class="terminal group">
  <div class="terminal-bar">
    <span class="dot dot-red"></span>
    <span class="dot dot-yellow"></span>
    <span class="dot dot-green"></span>
    <span class="flex-1 text-center text-[11px] text-[#555] group-hover:text-[#777] transition-colors -ml-[42px] font-mono">{title}</span>
  </div>
  <div class="p-5 sm:p-6 font-mono text-[13px] leading-relaxed text-[#b8b0a8]">
    <slot />
  </div>
</div>
