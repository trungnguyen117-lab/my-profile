---
interface Props {
  id: string;
  title: string;
  summary?: string;
  date?: string;
  tags?: { id: string; name: string }[];
}

const { id, title, summary, date, tags } = Astro.props;
---

<a href={`/blog/${id}`} class="group block card">
  <div class="flex items-baseline justify-between gap-6 mb-1">
    <h3 class="text-[15px] font-semibold leading-snug group-hover:text-accent transition-colors duration-300 tracking-tight">
      {title}
    </h3>
    {date && (
      <time class="shrink-0 text-xs text-text-3 tabular-nums font-mono">
        {new Date(date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
      </time>
    )}
  </div>
  {summary && <p class="text-sm text-text-2 line-clamp-1">{summary}</p>}
  {tags && tags.length > 0 && (
    <div class="flex gap-2 mt-2.5">
      {tags.map(t => <span class="tag-pill">#{t.name}</span>)}
    </div>
  )}
</a>
