---
const pathname = Astro.url.pathname;

const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/research', label: 'Research' },
  { href: '/blog', label: 'Blog' },
  { href: '/agent', label: 'Agent' },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header class="sticky top-0 z-40 bg-bg/80 backdrop-blur-xl backdrop-saturate-150">
  <nav class="max-w-[720px] mx-auto px-6 h-14 flex items-center justify-between">
    <a href="/" class="group flex items-center gap-1.5 font-mono text-sm font-semibold text-text-1 tracking-tight">
      <span class="text-accent opacity-70 group-hover:opacity-100 transition-opacity duration-300">&gt;_</span>
      trungnguye2n
    </a>

    <div class="hidden sm:flex items-center gap-7">
      {links.map(link => (
        <a
          href={link.href}
          data-astro-reload={link.href === '/agent' ? '' : undefined}
          class:list={[
            'font-mono text-xs transition-all duration-300 relative',
            isActive(link.href)
              ? 'text-text-1 font-medium'
              : 'text-text-3 hover:text-text-1',
          ]}
        >
          <span class="flex items-center gap-1.5">
            {link.label.toLowerCase()}
            {link.href === '/agent' && (
              <span class="text-[9px] font-mono px-1 py-0.5 rounded bg-accent/15 text-accent border border-accent/20">beta</span>
            )}
          </span>
          {isActive(link.href) && (
            <span class="absolute -bottom-1 left-0 right-0 h-px bg-accent opacity-50"></span>
          )}
        </a>
      ))}
    </div>

    <button id="mobile-btn" class="sm:hidden text-text-2 hover:text-text-1 transition-colors" aria-label="Menu">
      <svg class="w-5 h-5" id="ico-open" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5m-16.5 6.75h16.5"/>
      </svg>
      <svg class="w-5 h-5 hidden" id="ico-close" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </nav>

  <!-- Header gradient line -->
  <div class="header-line"></div>

  <div id="mobile-menu" class="hidden sm:hidden bg-bg/95 backdrop-blur-xl px-6 py-3 space-y-1 border-b border-border">
    {links.map(link => (
      <a
        href={link.href}
        data-astro-reload={link.href === '/agent' ? '' : undefined}
        class:list={[
          'block py-2.5 font-mono text-sm transition-colors',
          isActive(link.href) ? 'text-accent font-medium' : 'text-text-3',
        ]}
      >
        {link.label.toLowerCase()}
      </a>
    ))}
  </div>
</header>

<script>
  function initMobileMenu() {
    const btn = document.getElementById('mobile-btn');
    const menu = document.getElementById('mobile-menu');
    const o = document.getElementById('ico-open');
    const c = document.getElementById('ico-close');
    btn?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
      o?.classList.toggle('hidden');
      c?.classList.toggle('hidden');
    });
  }
  initMobileMenu();
  document.addEventListener('astro:after-swap', initMobileMenu);
</script>
