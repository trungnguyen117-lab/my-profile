---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  date?: string;
  tags?: string[];
  backLink?: { href: string; label: string };
}

const { title, description, date, tags, backLink } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <!-- Progress bar -->
  <div class="fixed top-0 left-0 w-full h-[2px] z-[60]">
    <div id="progress" class="h-full bg-text-1 w-0 transition-[width] duration-75"></div>
  </div>

  <article class="max-w-[680px] mx-auto reveal">
    {backLink && (
      <a href={backLink.href} class="inline-flex items-center gap-1.5 text-xs text-text-3 hover:text-text-1 transition-colors mb-12 font-mono">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
        {backLink.label.toLowerCase()}
      </a>
    )}

    <header class="mb-16">
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-[-0.04em] leading-tight mb-5">{title}</h1>
      <div class="flex flex-wrap items-center gap-4 text-xs text-text-3 font-mono">
        {date && <time class="tabular-nums">{new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>}
        {tags && tags.map(t => <span>#{t}</span>)}
      </div>
      <div class="h-px bg-border mt-10"></div>
    </header>

    <div class="prose"><slot /></div>
  </article>
</BaseLayout>

<script>
  const b = document.getElementById('progress');
  if (b) window.addEventListener('scroll', () => {
    const h = document.documentElement;
    b.style.width = `${Math.min((h.scrollTop / (h.scrollHeight - h.clientHeight)) * 100, 100)}%`;
  }, { passive: true });
</script>
