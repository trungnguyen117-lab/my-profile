---
import BaseLayout from '../layouts/BaseLayout.astro';
import Terminal from '../components/Terminal.astro';
import about from '../data/about.json';
---

<BaseLayout title="About — Trung Nguyen" description="CV and personal information">
  <div class="max-w-[680px] mx-auto">

    <!-- Header -->
    <div class="mb-20 reveal">
      <div class="flex items-start gap-8 mb-6">
        <div class="flex-1">
          <p class="font-mono text-xs text-text-3 mb-4 tracking-wider uppercase">about</p>
          <h1 class="text-4xl sm:text-5xl font-extrabold tracking-[-0.04em] mb-4">About me.</h1>
          <p class="text-lg text-text-2">{about.tagline}</p>
        </div>
        <div class="shrink-0">
          <img
            src="/profile.jpg"
            alt="Trung Nguyen"
            class="w-24 h-24 sm:w-28 sm:h-28 rounded-2xl object-cover"
          />
        </div>
      </div>
    </div>

    <!-- Bio -->
    <div class="mb-24 reveal" data-delay="0.1">
      <Terminal title="bio.md — preview">
        <div class="space-y-3 leading-relaxed">
          {about.bio.map(line => (
            <p set:html={line.replace(/<strong>(.*?)<\/strong>/g, '<span class="text-[#e8e2dd]">$1</span>')} />
          ))}
        </div>
      </Terminal>
    </div>

    <!-- Education -->
    <section class="mb-20 reveal" data-delay="0.15">
      <h2 class="font-mono text-xs text-text-3 uppercase tracking-widest mb-8">Education</h2>
      <div class="space-y-3">
        {about.education.map(e => (
          <div class="card grid grid-cols-[120px_1fr] gap-4">
            <span class="text-xs text-text-3 font-mono tabular-nums pt-0.5">{e.period}</span>
            <div>
              <h3 class="text-[15px] font-semibold tracking-tight">{e.title}</h3>
              <p class="text-sm text-text-2 mt-0.5">{e.org}</p>
              {e.note && <p class="text-sm text-text-3 mt-1">{e.note}</p>}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Experience -->
    <section class="mb-20 reveal" data-delay="0.2">
      <h2 class="font-mono text-xs text-text-3 uppercase tracking-widest mb-8">Experience</h2>
      <div class="space-y-3">
        {about.experience.map(e => (
          <div class="card grid grid-cols-[120px_1fr] gap-4">
            <span class="text-xs text-text-3 font-mono tabular-nums pt-0.5">{e.period}</span>
            <div>
              <div class="flex items-center gap-2">
                <h3 class="text-[15px] font-semibold tracking-tight">{e.title}</h3>
                {e.tag && <span class="text-[10px] font-mono px-1.5 py-0.5 rounded border border-text-3/30 text-text-3">{e.tag}</span>}
              </div>
              <p class="text-sm text-text-2 mt-0.5">{e.org}</p>
              {e.note && <p class="text-sm text-text-3 mt-1">{e.note}</p>}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Awards -->
    <section class="mb-20 reveal" data-delay="0.25">
      <h2 class="font-mono text-xs text-text-3 uppercase tracking-widest mb-8">Awards & Scholarships</h2>
      <div class="space-y-3">
        {about.awards.map(a => (
          <div class="card grid grid-cols-[120px_1fr] gap-4">
            <span class="text-xs text-text-3 font-mono tabular-nums pt-0.5">{a.year}</span>
            <div>
              <h3 class="text-[15px] font-semibold tracking-tight">{a.title}</h3>
              <p class="text-sm text-text-3 mt-0.5">{a.org}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Stack -->
    <section class="mb-20 reveal" data-delay="0.3">
      <h2 class="font-mono text-xs text-text-3 uppercase tracking-widest mb-8">Stack</h2>
      <Terminal title="stack.sh — zsh">
        <div class="space-y-1.5">
          {about.stack.map(s => (
            <p>
              <span class="text-[#666]">{s.label}</span>{'  '}
              <span class="text-[#e8e2dd]">{s.value}</span>
            </p>
          ))}
        </div>
      </Terminal>
    </section>

    <!-- CV Preview -->
    <section class="reveal" data-delay="0.35">
      <h2 class="font-mono text-xs text-text-3 uppercase tracking-widest mb-8">CV</h2>
      <div class="flex items-center justify-between">
        <button
          id="cv-toggle"
          class="flex items-center gap-2.5 px-5 py-2.5 rounded-lg bg-text-1 text-bg text-sm font-medium hover:bg-text-2 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
            <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/>
          </svg>
          View CV
        </button>
        <span class="text-xs font-mono text-text-3">updated {about.cv.updated}</span>
      </div>
      <div id="cv-panel" class="hidden mt-4 card p-0 overflow-hidden">
        <iframe
          src={about.cv.path}
          class="w-full h-[800px]"
          title="Nguyen Trung Nguyen — CV"
        />
      </div>
    </section>

    <script>
      function initCV() {
        const btn = document.getElementById('cv-toggle');
        const panel = document.getElementById('cv-panel');
        if (!btn || !panel) return;
        btn.addEventListener('click', () => panel.classList.toggle('hidden'));
      }
      document.addEventListener('astro:page-load', initCV);
    </script>

  </div>
</BaseLayout>
