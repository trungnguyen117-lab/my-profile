---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PaperCard from '../../components/PaperCard.astro';

let papers: any[] = [];
try {
  const { getCollection } = await import('astro:content');
  papers = await getCollection('papers');
} catch {}
---

<BaseLayout title="Research — Trung Nguyen" description="Research papers and publications">
  <div class="max-w-[680px] mx-auto">
    <div class="mb-20 reveal">
      <p class="font-mono text-xs text-text-3 mb-4 tracking-wider uppercase">research</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-[-0.04em] mb-4">Research.</h1>
      <p class="text-lg text-text-2">Published papers, preprints, and ongoing work.</p>
    </div>

    {papers.length > 0 ? (
      <div class="space-y-3 reveal" data-delay="0.1">
        {papers.map((p: any) => (
          <PaperCard
            id={p.id}
            title={p.data.properties?.Name?.title?.map((t: any) => t.plain_text).join('') || 'Untitled'}
            authors={p.data.properties?.Authors?.rich_text?.map((t: any) => t.plain_text).join('')}
            venue={p.data.properties?.Venue?.select?.name}
            date={p.data.properties?.['Publication Date']?.date?.start}
            status={p.data.properties?.Status?.select?.name}
            tags={p.data.properties?.Tags?.multi_select}
            pdfLink={p.data.properties?.['PDF Link']?.url}
          />
        ))}
      </div>
    ) : (
      <p class="text-text-3 reveal font-mono text-sm" data-delay="0.1">No papers yet. Connect your Notion database.</p>
    )}
  </div>
</BaseLayout>

<!-- PDF Modal -->
<div
  id="pdf-modal"
  class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm"
>
  <div class="relative w-full max-w-4xl h-[85vh] bg-bg-1 rounded-xl shadow-2xl flex flex-col overflow-hidden">
    <div class="flex items-center justify-between px-4 py-3 border-b border-border shrink-0">
      <span id="pdf-modal-title" class="text-sm font-mono text-text-2 truncate"></span>
      <button
        id="pdf-modal-close"
        class="ml-4 shrink-0 text-text-3 hover:text-text-1 transition-colors duration-200 text-xl leading-none"
        aria-label="Close"
      >&times;</button>
    </div>
    <iframe id="pdf-modal-frame" src="" class="flex-1 w-full border-0"></iframe>
  </div>
</div>

<script>
  function toEmbedUrl(url: string): string {
    const driveMatch = url.match(/drive\.google\.com\/file\/d\/([^/?]+)/);
    if (driveMatch) return `https://drive.google.com/file/d/${driveMatch[1]}/preview`;
    const openMatch = url.match(/drive\.google\.com\/open\?id=([^&]+)/);
    if (openMatch) return `https://drive.google.com/file/d/${openMatch[1]}/preview`;
    return url;
  }

  function initPdfModal() {
    const modal = document.getElementById('pdf-modal');
    const frame = document.getElementById('pdf-modal-frame') as HTMLIFrameElement;
    const titleEl = document.getElementById('pdf-modal-title');
    const closeBtn = document.getElementById('pdf-modal-close');
    if (!modal || !frame || !titleEl || !closeBtn) return;

    function closeModal() {
      modal!.classList.add('hidden');
      frame.src = '';
      document.body.style.overflow = '';
    }

    // Use AbortController to clean up listeners on next swap
    const ac = new AbortController();
    const { signal } = ac;

    document.addEventListener('open-pdf-modal', (e: Event) => {
      const { url, title } = (e as CustomEvent).detail;
      frame.src = toEmbedUrl(url);
      titleEl!.textContent = title;
      modal!.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }, { signal });

    closeBtn.addEventListener('click', closeModal, { signal });
    modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); }, { signal });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); }, { signal });

    // Clean up before next page swap
    document.addEventListener('astro:before-swap', () => ac.abort(), { once: true });
  }

  document.addEventListener('astro:page-load', initPdfModal);
</script>
