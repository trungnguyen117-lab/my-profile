---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';

let posts: any[] = [];
try {
  const { getCollection } = await import('astro:content');
  posts = await getCollection('posts');
} catch {}
---

<BaseLayout title="Blog — Trung Nguyen" description="Blog posts and thoughts">
  <div class="max-w-[680px] mx-auto">
    <div class="mb-20 reveal">
      <p class="font-mono text-xs text-text-3 mb-4 tracking-wider uppercase">blog</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-[-0.04em] mb-4">Blog.</h1>
      <p class="text-lg text-text-2">Thoughts, tutorials, and notes.</p>
    </div>

    {posts.length > 0 ? (
      <div class="space-y-3 reveal" data-delay="0.1">
        {posts.map((p: any) => (
          <BlogCard
            id={p.id}
            title={p.data.properties?.Name?.title?.map((t: any) => t.plain_text).join('') || 'Untitled'}
            summary={p.data.properties?.Summary?.rich_text?.map((t: any) => t.plain_text).join('')}
            date={p.data.properties?.Date?.date?.start}
            tags={p.data.properties?.Tags?.multi_select}
          />
        ))}
      </div>
    ) : (
      <p class="text-text-3 reveal font-mono text-sm" data-delay="0.1">No posts yet. Connect your Notion database.</p>
    )}
  </div>
</BaseLayout>
